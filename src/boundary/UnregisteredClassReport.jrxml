	<dataset name="UnregisteredDS" uuid="b0d1cd89-4b4f-4f62-b196-8ba50369cc81">
		<parameter name="pStart" class="java.sql.Date"/>
		<parameter name="pEnd" class="java.sql.Date"/>
		<query language="sql"><![CDATA[
SELECT
    TblTrainee.ID AS traineeID,
    TblTrainee.firstName,
    TblTrainee.lastName,
    TblTrainee.dateOfBirth,
    TblTrainee.phoneNumber,
    TblTrainee.email,
    Count(SubQ.classID) AS totalClasses
FROM
    TblTrainee
    LEFT JOIN (
        SELECT
            TblClassRegistrations.traineeID,
            TblTrainingClass.classID
        FROM
            TblClassRegistrations
            INNER JOIN TblTrainingClass
                ON TblClassRegistrations.classID = TblTrainingClass.classID
        WHERE
            TblTrainingClass.status = 'COMPLETED'
            AND TblTrainingClass.startTime >= $P{pStart}
            AND TblTrainingClass.startTime < DateAdd("d", 1, $P{pEnd})
    ) AS SubQ ON TblTrainee.ID = SubQ.traineeID
GROUP BY
    TblTrainee.ID,
    TblTrainee.firstName,
    TblTrainee.lastName,
    TblTrainee.dateOfBirth,
    TblTrainee.phoneNumber,
    TblTrainee.email
HAVING
    Count(SubQ.classID) < 7
ORDER BY
    Count(SubQ.classID) DESC,
    TblTrainee.lastName ASC,
    TblTrainee.firstName ASC;
		]]></query>
		<field name="traineeID" class="java.lang.Integer"/>
		<field name="firstName" class="java.lang.String"/>
		<field name="lastName" class="java.lang.String"/>
		<field name="dateOfBirth" class="java.sql.Date"/>
		<field name="phoneNumber" class="java.lang.String"/>
		<field name="email" class="java.lang.String"/>
		<field name="totalClasses" class="java.lang.Integer"/>
	</dataset>
	<parameter name="pStart" class="java.sql.Date"/>
	<parameter name="pEnd" class="java.sql.Date"/>
	<query language="sql"><![CDATA[]]></query>
